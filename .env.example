# Lovable Cloud (preenchido automaticamente em produção)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ListaCerta — produto
VITE_WHATSAPP_NUMBER=5565996076018
VITE_SITE_URL=https://listacertaescolar.com.br

# LC-008: visual mocks of Kalunga / Magalu retailers (UX-only).
# When 'true': the Edge Function build-cart expands the candidate pool
# with deterministic mock entries and the front shows DEMO badges +
# disclaimer banner. Set to 'false' (or unset) for production once
# real Kalunga/Magalu catalog integration ships (TD-13/14/18/19).
VITE_ENABLE_RETAILER_MOCKS=true
ENABLE_RETAILER_MOCKS=true

# LC-009: Mercado Livre affiliate program (TD-25). When tag is present,
# wrapPermalink appends affiliate tracking params to ML permalinks.
# Frontend reads VITE_ML_AFFILIATE_TAG; the build-cart Edge Function
# reads ML_AFFILIATE_TAG (no VITE_ prefix). Both must match.
# Leave empty for staging until real affiliate account is set up.
VITE_ML_AFFILIATE_TAG=
ML_AFFILIATE_TAG=

# LC-009: when 'true', the redirect page shows the
# AffiliateDisclosureBanner ("ganhamos uma pequena comissão"). Tie this
# to the affiliate tag — only enable when revenue actually flows.
VITE_AFFILIATE_DISCLOSURE_ENABLED=false
